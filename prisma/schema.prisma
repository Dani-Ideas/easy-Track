generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum CategoriaEvaluacion {
  SALONES
  SANITARIOS
  AREAS_COMUNES
}

// ─── Auth (NextAuth v5 Prisma Adapter) ───────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          Role      @default(STAFF)
  areaId        Int?
  area          Area?     @relation(fields: [areaId], references: [id])
  accounts      Account[]
  sessions      Session[]
  reportes      Reporte[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  STAFF
  ADMIN
  TECNICO
}

// ─── Facilities Domain ───────────────────────────────────────────────────────

model TipoEspacio {
  id                  Int                 @id @default(autoincrement())
  nombre              String              @db.VarChar(100)
  categoriaEvaluacion CategoriaEvaluacion
  activo              Boolean             @default(true)
  espacios            Espacio[]
}

model Grupo {
  id       Int       @id @default(autoincrement())
  nombre   String    @db.VarChar(100)
  activo   Boolean   @default(true)
  espacios Espacio[]
}

model Espacio {
  id            Int         @id @default(autoincrement())
  espacio       String      @db.VarChar(150)
  piso          String?     @db.VarChar(50)
  activo        Boolean     @default(true)
  idGrupo       Int
  idTipoEspacio Int
  grupo         Grupo       @relation(fields: [idGrupo], references: [id])
  tipoEspacio   TipoEspacio @relation(fields: [idTipoEspacio], references: [id])
  reportes      Reporte[]
}

model Personal {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(100)
  nombreNorm String   @unique @db.VarChar(100)
  createdAt  DateTime @default(now())
  areaId            Int?
  area              Area?     @relation(fields: [areaId], references: [id])
  rol               Role?
  reportesAsignados Reporte[] @relation("ReportePersonalResponsable")
}

enum EstadoReporte {
  PENDIENTE
  EN_PROCESO
  ATENDIDO
}

model Reporte {
  id                Int           @id @default(autoincrement())
  fechaCreacion     DateTime      @default(now())
  fechaInspeccion   DateTime
  nombreSolicitante String        @db.VarChar(50)
  tipoUbicacion     String        @db.VarChar(50)
  idEspacio         Int
  descripcion       String?       @db.VarChar(500)
  estado            EstadoReporte @default(PENDIENTE)
  areaResponsable   String?       @db.VarChar(50)
  observaciones     String?       @db.VarChar(500)
  fechaAtencion     DateTime?
  fechaResolucion   DateTime?
  // { limpieza: 1-5, seguridad: 1-5, iluminacion: bool, equipo: bool }
  evaluacion        Json?
  isDraft           Boolean       @default(false)

  espacio               Espacio   @relation(fields: [idEspacio], references: [id])
  creadoPor             User?     @relation(fields: [creadoPorId], references: [id])
  creadoPorId           String?
  personalResponsable   Personal? @relation("ReportePersonalResponsable", fields: [personalResponsableId], references: [id])
  personalResponsableId Int?
  logAcciones           LogAccion[]

  @@index([estado])
  @@index([tipoUbicacion])
  @@index([fechaCreacion])
}

// ─── Áreas responsables ──────────────────────────────────────────────────────

model Area {
  id          Int         @id @default(autoincrement())
  nombre      String      @unique @db.VarChar(100)
  activo      Boolean     @default(true)
  usuarios    User[]
  personal    Personal[]
  logAcciones LogAccion[]
}

// ─── Auditoría / bitácora ────────────────────────────────────────────────────

model LogAccion {
  id           Int      @id @default(autoincrement())
  createdAt    DateTime @default(now())
  usuarioLogin String   @db.VarChar(200)
  usuarioReal  String?  @db.VarChar(100)
  accion       String   @db.VarChar(200)
  detalle      String?  @db.VarChar(500)
  ip           String?  @db.VarChar(45)
  dispositivo  String?  @db.VarChar(200)
  areaId       Int?
  area         Area?    @relation(fields: [areaId], references: [id])
  reporteId    Int?
  reporte      Reporte? @relation(fields: [reporteId], references: [id])
}
